    {
      "text": "%spark.pyspark\ncity_product_metrics = (\n    enriched\n    .groupBy(\"city\",\"product_id\",\"product_name\")\n    .agg(\n        F.count(\"order_id\").alias(\"orders_cnt\"),\n        F.sum(\"qty\").alias(\"qty_sum\"),\n        F.sum(\"revenue\").alias(\"revenue_sum\"),\n    )\n    .orderBy(\"city\", F.desc(\"revenue_sum\"))\n)\ncity_product_metrics.show()",
