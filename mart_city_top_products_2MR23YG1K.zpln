      "text": "%spark.pyspark\nwindow_spec = Window.partitionBy(\"city\").orderBy(F.desc(\"revenue_sum\"))\n\nmart = (\n    city_product_metrics\n    .withColumn(\"rank\", F.rank().over(window_spec))\n    .filter(F.col(\"rank\") <= 2)\n    .drop(\"rank\")\n    .orderBy(\"city\", F.desc(\"revenue_sum\"))\n)\nmart.show()",
