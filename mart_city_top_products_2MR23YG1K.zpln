    {
      "text": "%spark.pyspark\n\nusers = spark.createDataFrame(\n    [(\"u1\",\"Berlin\"),(\"u2\",\"Berlin\"),(\"u3\",\"Munich\"),(\"u4\",\"Hamburg\")],\n    [\"user_id\",\"city\"]\n)\n\norders = spark.createDataFrame(\n    [(\"o1\",\"u1\",\"p1\",2,10.0),(\"o2\",\"u1\",\"p2\",1,30.0),(\"o3\",\"u2\",\"p1\",1,10.0),\n     (\"o4\",\"u2\",\"p3\",5,7.0),(\"o5\",\"u3\",\"p2\",3,30.0),(\"o6\",\"u3\",\"p3\",1,7.0),\n     (\"o7\",\"u4\",\"p1\",10,10.0)],\n    [\"order_id\",\"user_id\",\"product_id\",\"qty\",\"price\"]\n)\n\nproducts = spark.createDataFrame(\n    [(\"p1\",\"Ring VOLA\"),(\"p2\",\"Ring POROG\"),(\"p3\",\"Ring TISHINA\")],\n    [\"product_id\",\"product_name\"]\n)\n\nusers.show()\norders.show()\nproducts.show()",
